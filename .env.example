# Application
APP_NAME=Expense Tracker
APP_ENV=development
DEBUG=true

# Server
HOST=127.0.0.1
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/expense_tracker

# Security (change in production)
SECRET_KEY=change-me-to-a-long-random-secret-key

# Session
SESSION_COOKIE_NAME=expense_tracker_session
SESSION_MAX_AGE=86400

# Logging
LOG_LEVEL=INFO
